{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://4kub.ru/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://4kub.ru"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "rustore": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "production",
        "MARKET_CODE": "RU",
        "EXPO_PUBLIC_API_URL": "https://4kub.ru/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://4kub.ru"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "huawei": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "production",
        "MARKET_CODE": "RU",
        "EXPO_PUBLIC_API_URL": "https://4kub.ru/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://4kub.ru"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "thiofedor@gmail.com",
        "ascAppId": "6776447873",
        "appleTeamId": "C924RZ5S3J"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
