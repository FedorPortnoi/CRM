{
  "expo": {
    "name": "4KUB",
    "slug": "crm",
    "version": "1.0.1",
    "owner": "flada",
    "scheme": "crm",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fedorportnoi.crm",
      "buildNumber": "14",
      "infoPlist": {
        "CFBundleDisplayName": "4КУБ",
        "NSLocationWhenInUseUsageDescription": "CRM uses your location for field visit tracking.",
        "NSContactsUsageDescription": "CRM can import contacts from your phone.",
        "NSCameraUsageDescription": "CRM uses the camera to scan business cards.",
        "NSPhotoLibraryUsageDescription": "CRM lets you choose business card images from your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fedorportnoi.crm",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "./plugins/withAndroidDisplayName",
        "4КУБ"
      ],
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "CRM lets you choose business card images from your photo library.",
          "cameraPermission": "CRM uses the camera to scan business cards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrls": {
        "development": "http://10.80.1.215:3000/api/v1"
      },
      "eas": {
        "projectId": "63759f24-3860-43b6-ac4f-cec8180d63c3"
      }
    }
  }
}
