{
  "expo": {
    "name": "CRM",
    "slug": "crm",
    "version": "1.0.0",
    "owner": "fedorportnoi",
    "scheme": "crm",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A73E8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fedorportnoi.crm",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CRM uses your location for field visit tracking.",
        "NSContactsUsageDescription": "CRM can import contacts from your phone.",
        "NSCameraUsageDescription": "CRM uses the camera to scan business cards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A73E8"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fedorportnoi.crm",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrls": {
        "development": "http://192.168.5.249:3000/api/v1",
        "staging": "https://staging.railway.app/api/v1",
        "production": "https://api.railway.app/api/v1"
      }
    }
  }
}