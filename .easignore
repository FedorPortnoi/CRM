# EAS upload ignore list. Mirrors .gitignore, EXCEPT it force-includes
# google-services.json (gitignored, but required by managed Android builds)
# and always ignores local native projects so EAS prebuilds from app.json.

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment — never upload secrets
.env
.env.local
.env.*.local
firebase-service-account.json
google-services.json

# Build outputs
dist/
build/
web-build/
.expo/
.expo-shared/
ios/build/
android/build/
android/.gradle/
coverage/

# Release artifacts
*.apk
*.aab
*.ipa
*.pem

# Sensitive
certs/
docs/Российские*
docs/*доступы*

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local run artifacts
/codex-*.txt
/codex-*.md
/tmp-*.txt
/tmp-test-runs/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# TypeScript / tooling
*.tsbuildinfo
.turbo/

# Playwright
tests/smoke/.auth.json
test-results/
playwright-report/

expo-env.d.ts

# Always use EAS managed prebuild (ignore any locally-generated native projects)
/android/
/ios/

# Force-include the Firebase Android config the managed build needs
!google-services.json
