# ============================================================
# Mobile CRM Platform — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Authentication (JWT) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# --- Mobile App (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# --- Push Notifications ---
# Expo Push (development)
EXPO_ACCESS_TOKEN=

# FCM (Firebase Cloud Messaging — Android)
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# APNS (Apple Push Notification — iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./certs/apns.p8

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Email Integration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- Google Calendar Integration ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/calendar/google/callback

# --- File Storage (AWS S3 or compatible) ---
S3_BUCKET=crm-uploads
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_UPLOAD_SIZE_MB=10

# --- OCR / Business Card Scanning ---
GOOGLE_VISION_API_KEY=

# --- Error Monitoring ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Analytics (internal, not customer-facing) ---
MIXPANEL_TOKEN=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
