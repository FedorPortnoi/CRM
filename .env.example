# ============================================================
# Mobile CRM Platform — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# --- Yandex Managed PostgreSQL (when migrating from Supabase) ---
# Download the Yandex root CA: https://storage.yandexcloud.net/cloud-certs/CA.pem
# Save it locally and set the path below.
YANDEX_DB_SSL_CA=/path/to/yandex-ca.pem
# For Yandex Managed PostgreSQL, DATABASE_URL takes this form:
# postgresql://user:password@<cluster-host>.mdb.yandexcloud.net:6432/crm_db?sslmode=require&sslrootcert=/path/to/yandex-ca.pem
DIRECT_URL=

DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Authentication (JWT) ---
JWT_SECRET=
TOKEN_ENCRYPTION_KEY=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# --- Mobile App (Expo) ---
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# --- Push Notifications ---
# Expo Push (development)
EXPO_ACCESS_TOKEN=

# FCM (Firebase Cloud Messaging — Android)
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# APNS (Apple Push Notification — iOS)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./certs/apns.p8

# --- SMS (SMS.ru) ---
# Required for SMS.ru outbound sending and inbound webhook validation.
SMSRU_API_ID=
SMSRU_SENDER=CRM

# --- Email Integration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- Yandex Calendar Integration (CalDAV) ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/api/v1/calendar/sync/yandex/callback
YANDEX_CALENDAR_SUCCESS_URL=crm://calendar

# --- File Storage (AWS S3 or compatible) ---
S3_BUCKET=crm-uploads
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_UPLOAD_SIZE_MB=10

# --- Yandex Vision OCR / SpeechKit ---
# Required for business-card OCR from images and voice transcription.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Error Monitoring ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Analytics (internal, not customer-facing) ---
MIXPANEL_TOKEN=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
