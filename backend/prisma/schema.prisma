// Prisma schema for Mobile CRM Platform
// Prisma 5.13.0 | PostgreSQL (Supabase)

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  owner
  admin
  member
  viewer
}

enum OrgPlan {
  starter
  growth
  business
}

enum ContactType {
  lead
  customer
  partner
  other
}

enum ContactStatus {
  active
  inactive
  archived
}

enum DealStatus {
  open
  won
  lost
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageChannel {
  sms
  in_app
  email
  call
}

enum MessageStatus {
  pending
  sent
  delivered
  read
  failed
}

enum CalendarEventStatus {
  scheduled
  completed
  cancelled
}

enum WorkflowStatus {
  active
  paused
  archived
}

enum WorkflowTrigger {
  contact_created
  deal_stage_changed
  task_completed
  deal_won
  deal_created
  task_created
  deal_stale
}

enum WorkflowRunStatus {
  success
  failed
}

enum PendingCaptureType {
  call
  sms
  email
}

enum PendingCaptureStatus {
  pending
  matched
  dismissed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String    @db.Uuid
  email             String?   @unique @db.Citext
  username          String?   @db.Citext
  password_hash     String
  name              String
  role              UserRole  @default(member)
  avatar_url        String?
  phone             String?
  is_active              Boolean   @default(true)
  onboarding_state       Json?
  preferences            Json?
  last_seen_at           DateTime?
  invited_by             String?   @db.Uuid
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  push_token             String?
  failed_login_count     Int       @default(0)
  locked_until           DateTime?
  is_verified            Boolean   @default(false)
  phone_verified         Boolean   @default(false)
  email_verified         Boolean   @default(false)
  must_change_password   Boolean   @default(false)
  must_change_email      Boolean   @default(false)

  // Relations
  organization     Org       @relation("UserOrg", fields: [organization_id], references: [id])
  inviter          User?     @relation("UserInviter", fields: [invited_by], references: [id])
  invitees         User[]    @relation("UserInviter")
  ownedOrgs        Org[]     @relation("OrgOwner")
  assignedContacts Contact[] @relation("ContactAssignedTo")
  createdContacts  Contact[] @relation("ContactCreatedBy")
  assignedDeals    Deal[]    @relation("DealAssignedTo")
  createdDeals     Deal[]    @relation("DealCreatedBy")
  assignedTasks    Task[]    @relation("TaskAssignedTo")
  createdTasks     Task[]    @relation("TaskCreatedBy")
  completedTasks        Task[]              @relation("TaskCompletedBy")
  messages              Message[]
  calendarEventsCreated CalendarEvent[]     @relation("CalendarEventCreatedBy")
  calendarSyncs         UserCalendarSync[]
  createdPipelines      Pipeline[]          @relation("PipelineCreatedBy")
  createdWorkflows      Workflow[]          @relation("WorkflowCreatedBy")
  authSessions          AuthSession[]
  auditEvents           AuditEvent[]
  activityLogs          ActivityLog[] @relation("ActivityLogUser")
  uploadedAttachments   Attachment[]  @relation("AttachmentUploader")
  verificationCodes     VerificationCode[]
  chatMessages          ChatMessage[]      @relation("ChatMessageSender")
  chatReadReceipts      ChatReadReceipt[]  @relation("ChatReadReceiptUser")
  notifications         Notification[]     @relation("NotificationRecipient")

  // Employees log in by username, which only needs to be unique inside their org.
  @@unique([organization_id, username])
}

model Org {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String   @unique
  plan          OrgPlan  @default(starter)
  owner_id      String?  @db.Uuid
  settings      Json?
  plan_features           Json?
  stalled_threshold_days  Int     @default(30)
  decay_factor            Float   @default(0.5)
  join_code               String?   @unique
  join_code_expires_at    DateTime?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  // Relations
  owner    User?     @relation("OrgOwner", fields: [owner_id], references: [id])
  users    User[]    @relation("UserOrg")
  contacts Contact[]
  deals    Deal[]
  tasks          Task[]
  messages       Message[]
  calendarEvents CalendarEvent[]
  pipelines       Pipeline[]
  workflows       Workflow[]
  pendingCaptures PendingCapture[]
  authSessions    AuthSession[]
  auditEvents     AuditEvent[]
  activityLogs    ActivityLog[]
  attachments     Attachment[]
  chatMessages    ChatMessage[]  @relation("ChatMessageOrg")
  notifications   Notification[] @relation("NotificationOrg")

  @@map("organizations")
}

model AuthSession {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  user_id         String    @db.Uuid
  token_hash      String    @unique
  user_agent      String?
  ip_address      String?
  revoked_at      DateTime?
  revoked_reason  String?
  last_seen_at    DateTime?
  expires_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization Org  @relation(fields: [organization_id], references: [id])
  user         User @relation(fields: [user_id], references: [id])

  @@index([user_id, revoked_at])
  @@index([organization_id, created_at])
}

model AuditEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?  @db.Uuid
  user_id         String?  @db.Uuid
  action          String
  outcome         String   @default("success")
  target_type     String?
  target_id       String?
  ip_address      String?
  user_agent      String?
  metadata        Json?
  created_at      DateTime @default(now())

  organization Org?  @relation(fields: [organization_id], references: [id])
  user         User? @relation(fields: [user_id], references: [id])

  @@index([organization_id, created_at])
  @@index([user_id, created_at])
  @@index([action, created_at])
}

model Contact {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  first_name      String
  last_name       String?
  company         String?
  email           String?
  phone           String?
  mobile          String?
  address         Json?
  /// Stored as a JSON array (mirrors PostgreSQL text[] column)
  tags            Json?
  source          String?
  notes           String?
  avatar_url      String?
  assigned_to     String?       @db.Uuid
  type            ContactType   @default(lead)
  status          ContactStatus @default(active)
  custom_fields   Json?
  is_example_data Boolean       @default(false)
  created_by      String?       @db.Uuid
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Relations
  organization Org      @relation(fields: [organization_id], references: [id])
  assignee     User?    @relation("ContactAssignedTo", fields: [assigned_to], references: [id])
  creator      User?    @relation("ContactCreatedBy", fields: [created_by], references: [id])
  deals           Deal[]
  tasks           Task[]
  messages        Message[]
  calendarEvents  CalendarEvent[]
  pendingCaptures PendingCapture[]

  @@index([organization_id, status])
  @@index([organization_id, created_at])
}

model Deal {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String     @db.Uuid
  title           String
  contact_id      String     @db.Uuid
  pipeline_id     String?    @db.Uuid
  stage_id        String?    @db.Uuid
  value           Decimal?
  currency        String?    @default("RUB")
  expected_close  DateTime?
  actual_close    DateTime?
  probability     Int?
  status          DealStatus @default(open)
  lost_reason     String?
  next_action      String?
  next_action_due  DateTime?
  stage_entered_at DateTime   @default(now())
  source          String?
  assigned_to     String?    @db.Uuid
  custom_fields   Json?
  is_example_data Boolean    @default(false)
  created_by      String?    @db.Uuid
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  // Relations
  organization Org      @relation(fields: [organization_id], references: [id])
  contact      Contact  @relation(fields: [contact_id], references: [id])
  assignee       User?           @relation("DealAssignedTo", fields: [assigned_to], references: [id])
  creator        User?           @relation("DealCreatedBy", fields: [created_by], references: [id])
  pipeline       Pipeline?       @relation(fields: [pipeline_id], references: [id])
  stage          PipelineStage?  @relation(fields: [stage_id], references: [id])
  tasks          Task[]
  calendarEvents CalendarEvent[]

  @@index([organization_id, status])
  @@index([organization_id, created_at])
  @@index([organization_id, contact_id])
  @@index([organization_id, pipeline_id])
}

model Task {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  title           String
  description     String?
  contact_id      String?      @db.Uuid
  deal_id         String?      @db.Uuid
  assigned_to     String       @db.Uuid
  created_by      String?      @db.Uuid
  due_date        DateTime?
  priority        TaskPriority @default(medium)
  status          TaskStatus   @default(pending)
  is_recurring    Boolean      @default(false)
  recurrence_rule String?
  reminder_at     DateTime?
  completed_at    DateTime?
  completed_by    String?      @db.Uuid
  is_example_data Boolean      @default(false)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  organization Org      @relation(fields: [organization_id], references: [id])
  contact      Contact? @relation(fields: [contact_id], references: [id])
  deal         Deal?    @relation(fields: [deal_id], references: [id])
  assignee     User     @relation("TaskAssignedTo", fields: [assigned_to], references: [id])
  creator      User?    @relation("TaskCreatedBy", fields: [created_by], references: [id])
  completer    User?    @relation("TaskCompletedBy", fields: [completed_by], references: [id])

  @@index([organization_id, status, due_date])
  @@index([organization_id, created_at])
  @@index([organization_id, contact_id])
  @@index([organization_id, deal_id])
}

model Message {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  contact_id      String           @db.Uuid
  user_id         String?          @db.Uuid
  direction       MessageDirection
  channel         MessageChannel
  body            String
  status          MessageStatus    @default(pending)
  error_message   String?
  twilio_sid      String?
  read_at         DateTime?
  delivered_at    DateTime?
  created_at      DateTime         @default(now())

  // Relations
  organization Org      @relation(fields: [organization_id], references: [id])
  contact      Contact  @relation(fields: [contact_id], references: [id])
  user         User?    @relation(fields: [user_id], references: [id])

  @@index([organization_id, created_at])
  @@index([organization_id, contact_id, created_at])
}

model CalendarEvent {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String              @db.Uuid
  title                 String
  description           String?
  contact_id            String?             @db.Uuid
  deal_id               String?             @db.Uuid
  created_by            String?             @db.Uuid
  attendee_ids          Json?
  start_time            DateTime
  end_time              DateTime
  location              String?
  meeting_url           String?
  reminder_minutes      Int                 @default(30)
  status                CalendarEventStatus @default(scheduled)
  notes                 String?
  completed_at          DateTime?
  post_meeting_prompted Boolean             @default(false)
  ext_event_uid         String?
  ext_calendar_uid      String?
  is_example_data       Boolean             @default(false)
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  // Relations
  organization Org      @relation(fields: [organization_id], references: [id])
  contact      Contact? @relation(fields: [contact_id], references: [id])
  deal         Deal?    @relation(fields: [deal_id], references: [id])
  creator      User?    @relation("CalendarEventCreatedBy", fields: [created_by], references: [id])

  @@index([organization_id, status, start_time])
  @@index([organization_id, created_at])
  @@index([organization_id, contact_id])
  @@index([organization_id, deal_id])
}

model UserCalendarSync {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  provider            String
  access_token        String
  refresh_token       String?
  expires_at          DateTime?
  ext_calendar_uid    String?
  yandex_username     String?
  yandex_calendar_slug String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, provider])
}

model Pipeline {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  description     String?
  is_default      Boolean  @default(false)
  created_by      String?  @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organization Org             @relation(fields: [organization_id], references: [id])
  creator      User?           @relation("PipelineCreatedBy", fields: [created_by], references: [id])
  stages       PipelineStage[]
  deals        Deal[]
}

model PipelineStage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipeline_id   String   @db.Uuid
  name          String
  position      Int
  color         String?
  is_won_stage  Boolean  @default(false)
  is_lost_stage Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  pipeline Pipeline @relation(fields: [pipeline_id], references: [id])
  deals    Deal[]
}

model Workflow {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  name            String
  description     String?
  trigger         WorkflowTrigger
  conditions      Json?
  actions         Json
  status          WorkflowStatus  @default(active)
  created_by      String?         @db.Uuid
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  organization Org           @relation(fields: [organization_id], references: [id])
  creator      User?         @relation("WorkflowCreatedBy", fields: [created_by], references: [id])
  runs         WorkflowRun[]

  @@index([organization_id, status, trigger])
}

model WorkflowRun {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id       String            @db.Uuid
  organization_id   String            @db.Uuid
  trigger_record_id String?
  status            WorkflowRunStatus
  error_message     String?
  created_at        DateTime          @default(now())

  workflow Workflow @relation(fields: [workflow_id], references: [id])

  @@index([organization_id, created_at])
  @@index([workflow_id, created_at])
}

model PendingCapture {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id       String                @db.Uuid
  type         PendingCaptureType
  raw_data     Json
  phone_number String?
  status       PendingCaptureStatus  @default(pending)
  contact_id   String?               @db.Uuid
  created_at   DateTime              @default(now())

  org     Org      @relation(fields: [org_id], references: [id])
  contact Contact? @relation(fields: [contact_id], references: [id])

  @@index([org_id, status])
  @@index([org_id, created_at])
}

model ActivityLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String?  @db.Uuid
  entity_type     String
  entity_id       String   @db.Uuid
  action          String
  changes         Json?
  created_at      DateTime @default(now())
  organization Org   @relation(fields: [organization_id], references: [id])
  user         User? @relation("ActivityLogUser", fields: [user_id], references: [id])
  @@index([organization_id, entity_type, entity_id])
  @@index([organization_id, created_at])
}
model Attachment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  entity_type     String
  entity_id       String   @db.Uuid
  filename        String
  file_url        String
  size            Int?
  mime_type       String?
  uploaded_by     String?  @db.Uuid
  created_at      DateTime @default(now())
  organization Org   @relation(fields: [organization_id], references: [id])
  uploader     User? @relation("AttachmentUploader", fields: [uploaded_by], references: [id])
  @@index([organization_id, entity_type, entity_id])
}

model VerificationCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String
  channel    String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, channel])
}
model ChatMessage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  sender_id       String   @db.Uuid
  channel         String
  body            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Org  @relation("ChatMessageOrg", fields: [organization_id], references: [id])
  sender       User @relation("ChatMessageSender", fields: [sender_id], references: [id])

  @@index([organization_id, channel, created_at(sort: Desc)])
}

model ChatReadReceipt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String   @db.Uuid
  channel         String
  last_read_at    DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation("ChatReadReceiptUser", fields: [user_id], references: [id])

  @@unique([user_id, channel])
  @@index([organization_id, user_id])
}

model Notification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  recipient_id    String    @db.Uuid
  event_type      String
  role            String
  title           String
  body            String
  entity_type     String
  entity_id       String    @db.Uuid
  data            Json?
  is_read         Boolean   @default(false)
  read_at         DateTime?
  created_at      DateTime  @default(now())

  organization Org  @relation("NotificationOrg", fields: [organization_id], references: [id])
  recipient    User @relation("NotificationRecipient", fields: [recipient_id], references: [id])

  @@index([recipient_id, is_read, created_at(sort: Desc)])
  @@index([organization_id, created_at])
}

model NotificationSent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type   String
  entity_id    String   @db.Uuid
  recipient_id String   @db.Uuid
  created_at   DateTime @default(now())

  @@unique([event_type, entity_id, recipient_id])
  @@index([created_at])
}
