{
  "spellcheck": true,
  "spellcheckLanguages": ["en"],
  "showLineNumber": true,
  "readableLineLength": true,
  "defaultViewMode": "preview",
  "livePreview": true,
  "legacyEditor": false,
  "foldHeading": true,
  "foldIndent": true,
  "showFrontmatter": false,
  "strictLineBreaks": false,
  "smartIndentList": true,
  "tabSize": 2,
  "useTab": false,
  "autoPairBrackets": true,
