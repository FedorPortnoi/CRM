{
  "name": "mobile-crm-platform",
  "version": "1.0.0",
  "description": "Mobile-first CRM for SMBs — Simple. Visual. Powerful.",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend:dev": "tsx watch backend/index.ts",
    "backend:build": "tsc -p backend/tsconfig.json --outDir dist/backend",
    "backend:start": "node dist/backend/index.js",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "db:seed": "tsx backend/db/seeds/index.ts",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "lint": "eslint src backend --ext .ts,.tsx",
    "lint:fix": "eslint src backend --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'backend/**/*.ts'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@fastify/cors": "^11.0.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.13.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.43.0",
    "@tanstack/query-async-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.0",
    "expo-background-fetch": "~14.0.0",
    "expo-calendar": "~15.0.0",
    "expo-camera": "~17.0.0",
    "expo-constants": "~18.0.0",
    "expo-contacts": "~15.0.0",
    "expo-document-picker": "~14.0.0",
    "expo-file-system": "~19.0.0",
    "expo-image-picker": "~17.0.0",
    "expo-linking": "~8.0.0",
    "expo-location": "~19.0.0",
    "expo-notifications": "~0.32.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-server-sdk": "^6.1.0",
    "expo-speech": "~14.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-task-manager": "~14.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "i18next": "^25.10.10",
    "lucide-react-native": "^1.14.0",
    "pdfkit": "^0.18.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.7.4",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1304.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^12.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitest/coverage-v8": "^1.5.0",
    "detox": "^20.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0",
    "tsx": "^4.8.2",
    "typescript": "~5.9.2",
    "vitest": "^1.5.0"
  }
}
