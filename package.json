{
  "name": "mobile-crm-platform",
  "version": "0.1.0",
  "description": "Mobile-first CRM for SMBs — Simple. Visual. Powerful.",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend:dev": "tsx watch backend/index.ts",
    "backend:build": "tsc -p backend/tsconfig.json --outDir dist/backend",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "db:seed": "tsx backend/db/seeds/index.ts",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "lint": "eslint src backend --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'backend/**/*.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^5.13.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tanstack/react-query": "^5.28.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-calendar": "~13.0.0",
    "expo-camera": "~15.0.0",
    "expo-contacts": "~13.0.0",
    "expo-file-system": "~17.0.0",
    "expo-image-picker": "~15.0.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-speech": "~12.0.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "lucide-react-native": "^1.14.0",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-calendars": "^1.1304.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "~3.31.0",
    "react-native-svg": "15.2.0",
    "twilio": "^5.1.0",
    "winston": "^3.13.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^12.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/react": "~18.2.0",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitest/coverage-v8": "^1.5.0",
    "detox": "^20.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
